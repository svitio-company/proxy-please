# =============================================================================
# svitio-transparent-proxy — deployment configuration
# Copy to .env and fill in your values.
# Uncomment "env_file: .env" in docker-compose.yml to use this file.
# =============================================================================

# Comma-separated list of allowed egress hostnames.
# Supports exact matches and single-level wildcards (*.example.com).
# Leave empty to deny ALL outbound traffic (default-deny).
#
# Examples:
#   ALLOWED_HOSTS=example.com
#   ALLOWED_HOSTS=example.com,*.microsoft.com,api.github.com
#   ALLOWED_HOSTS=*.blob.core.windows.net,*.vault.azure.net,login.microsoftonline.com
ALLOWED_HOSTS=

# Log verbosity: error | warn | info | debug | trace
# Use "info" in production. Use "debug" to log every connection decision.
RUST_LOG=info
